<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutDiary.Views.AddExercisePage"
             xmlns:viewModels="clr-namespace:WorkoutDiary.ViewModels"
             Title="{Binding PageTitle}" Shell.TitleColor="{DynamicResource PrimaryColor}"
             BackgroundImageSource="titleapp.jpg">
    
    <ScrollView>


        <Grid RowDefinitions="auto,auto" ColumnDefinitions="*,*" >
            <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*" Margin="5,5,5,0" Padding="20" ZIndex="1">
                <VerticalStackLayout Grid.Column="0" Grid.RowSpan="1">
                    <Label Text="Dodaj siłownie" Grid.Column="0" TextColor="Black" Grid.Row="0"/>
                    <Entry x:Name="GymEditor" Grid.Row="1" Grid.Column="0"
                       Placeholder="Dodaj siłownie"
                       PlaceholderColor="Gray"
                         Text="{Binding Gym}" TextColor="{DynamicResource PrimaryColor}"/>
                </VerticalStackLayout>
                <!--<Picker x:Name="namePickerGym" BackgroundColor="{DynamicResource PageBackgroundColor}" Margin="0,0,0,0"
                        Title="Wybierz z listy" HorizontalOptions="Center" Grid.Column="1"
                        TitleColor="Gray" Grid.Row="1" Background="Transparent"
                        ItemsSource="{Binding TitleGym}"
                        SelectedItem="{Binding GymPicker}"
                        TextColor="{DynamicResource PrimaryColor}"/>-->

                <VerticalStackLayout Grid.Column="1" Grid.RowSpan="1">
                    <Label Text="Wybrana siłownia" Grid.Column="1" TextColor="Black" Grid.Row="0"/>
                    <Border  Stroke="Transparent" Margin="2">

                    <Label Text="{Binding GymPicker, TargetNullValue='Wybierz siłownię'}"
                                HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                                FontSize="15"
                                TextColor="#8cca68">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PickGymCommand}" />
                        </Label.GestureRecognizers>

                    </Label>

                </Border>
                    <Border StrokeThickness="0.4" Padding="0" Margin="4"/>
                </VerticalStackLayout>
            </Grid>



            <Grid Margin="5,0,5,0" VerticalOptions="Center" ColumnSpacing="5" Padding="20" Grid.Row="1" Grid.ColumnSpan="2" RowSpacing="5" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackLayout  Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    
                
                <Label  TextColor="{DynamicResource PrimaryColor}" Text="Dodaj ćwiczenie"/>
                <ImageButton  Command="{Binding ButtonInfo}"
                              Scale="1.2" HeightRequest="15"  BackgroundColor="#8cca68"
                             Padding="0"
                             Source="info.svg"/>
                </StackLayout>



                <Entry Grid.Row="2" Grid.ColumnSpan="2" x:Name="PartEditor"
                       Placeholder="np: Biceps - sztanga łamana" FontSize="15"
                       PlaceholderColor="Gray"
                         Text="{Binding Part}" TextColor="{DynamicResource PrimaryColor}"
                         HeightRequest="40" />


                <VerticalStackLayout  Grid.Row="3"  Grid.Column="0">
                    <Label Text="zapisane ćwiczenia" IsVisible="{Binding ShowSuggestions}"/>

                    <Border
                               StrokeThickness="0"
                               Stroke="Transparent"
                               BackgroundColor="Transparent"
                        Margin="0"
                               IsVisible="{Binding ShowSuggestions}">

                        <CollectionView
                                ItemsSource="{Binding Suggestions}"
                                SelectionChangedCommand="{Binding SuggestionSelectedCommand}"
                                SelectionChangedCommandParameter="{Binding Source={RelativeSource Self}, Path=SelectedItem}"
                                SelectionMode="Single"
                                BackgroundColor="Transparent"
                                VerticalOptions="Start"
                                MaximumHeightRequest="200">
                            <!-- AUTOMATYCZNA WYSOKOŚĆ + LIMIT -->

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border Padding="5" Stroke="#8cca68">
                                        <Label Text="{Binding Part}" FontSize="15" TextColor="Black" />
                                    </Border>



                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </Border>
                </VerticalStackLayout>
                <!--<Frame
                        BackgroundColor="#FFEEEE" BorderColor="Red" Padding="8" CornerRadius="6" IsVisible="{Binding IsPartDuplicate}">

                        <Label Text="Takie ćwiczenie już istnieje!" TextColor="Red" FontAttributes="Bold" />
                    </Frame>-->
                <VerticalStackLayout Grid.Row="4" Grid.ColumnSpan="2">

                    <Label Text="LUB" IsVisible="{Binding ShowLabelLUB}" TextColor="{DynamicResource PrimaryColor}" HorizontalOptions="Center" FontSize="15"/>
                    <Label Text="Wybrane ćwiczenie" IsVisible="{Binding ShowLabel}" TextColor="{DynamicResource PrimaryColor}" HorizontalOptions="Start" />

                    <!--<Picker x:Name="namePicker" BackgroundColor="{DynamicResource PageBackgroundColor}" Margin="0,0,0,0"
                        Title="Wybierz ćwiczenie z listy"
                        TitleColor="Gray" Background="Transparent"
                        HeightRequest="40"
                        TextColor="{DynamicResource PrimaryColor}"
                        SelectedIndexChanged="PartSelected">
                </Picker>-->
                    <Border Stroke="Transparent" Margin="2">

                        <Label Text="{Binding PartPicker, TargetNullValue='Wybierz ćwiczenie z listy'}"
                              HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                              FontSize="15"
                              TextColor="#8cca68">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickPartCommand}" />
                            </Label.GestureRecognizers>

                        </Label>

                    </Border>
                    <Border StrokeThickness="0.4" Padding="0" Margin="4"/>
                </VerticalStackLayout>
                <Entry Grid.Row="5" Grid.ColumnSpan="2" x:Name="CommentEditor"
                       Placeholder="Komentarz do treningu" FontSize="15"
                       PlaceholderColor="Gray"
                         Text="{Binding Comment}" TextColor="{DynamicResource PrimaryColor}"
                         HeightRequest="40" />
                <Label Grid.Row="6" Grid.Column="0" HorizontalOptions="Start" VerticalOptions="Center" TextColor="{DynamicResource PrimaryColor}" Text="Data ćwiczenia"/>
                <Image Grid.Row="7" Grid.Column="0" BackgroundColor="#8cca68" HorizontalOptions="Start" HeightRequest="30" Source="calendar.svg"/>
                <DatePicker x:Name="datepickerEditor" Grid.Row="7" Grid.Column="0"
                            DateSelected="DatePicker_DateSelected" FontSize="15"
                            HorizontalOptions="Start" Format="dd.MM.yyyy" Opacity="0" />
                <Label Grid.Row="7" Grid.ColumnSpan="1" Margin="40,0,0,0" x:Name="DatetimeEditor" TextColor="{DynamicResource PrimaryColor}"
                        Text="{Binding DatetimeEntry, StringFormat='{0:dd.MM.yyyy}'}" 
                        HeightRequest="40"  VerticalTextAlignment="Center" TextDecorations="Underline" />
                <Label Grid.Row="8" Grid.ColumnSpan="2" Text="Dane treningu" TextColor="{DynamicResource PrimaryColor}"/>
                <Entry Grid.Row="9" Grid.ColumnSpan="2" x:Name="SeriesEditor"
                        Keyboard="Numeric" Placeholder="Wpisz ilość serii" FontSize="15"
                       PlaceholderColor="Gray" TextColor="{DynamicResource PrimaryColor}"
                        Text="{Binding Series}"  Completed="Entry_Completed"
                        HeightRequest="40" />
                <Entry Grid.Row="10" x:Name="RepetitionsEditor" Placeholder="Wpisz ilość powtórzeń"
                        Keyboard="Numeric" Grid.ColumnSpan="2" Completed="Entry_Completed" FontSize="15"
                       PlaceholderColor="Gray" TextColor="{DynamicResource PrimaryColor}"
                        Text="{Binding Repetitions}" 
                        HeightRequest="40" />
                <Entry Grid.Row="11" Grid.ColumnSpan="2" x:Name="WeightEditor"
                        Keyboard="Numeric" Placeholder="Wpisz obciążenie" FontSize="15"
                       PlaceholderColor="Gray" TextColor="{DynamicResource PrimaryColor}"
                        Text="{Binding Weight}" Completed="Entry_save_Completed"
                        HeightRequest="40" />

                <Button Grid.Row="12" Grid.ColumnSpan="2" Text="Zapisz"
                        x:Name="save" FontSize="15" 
                        Command="{Binding SaveCommand}"
                        Background="#8cca68" 
                        TextColor="{DynamicResource PrimaryColor}"/>


            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>